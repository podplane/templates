{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "images": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "string",
          "description": "App container image"
        },
        "caddy": {
          "type": "string",
          "description": "Caddy sidecar image"
        }
      }
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "object",
          "description": "Non-secret environment variables for the app container",
          "additionalProperties": {
            "type": "string"
          }
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Plain HTTP port exposed by the app container"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostname": {
          "type": "string",
          "description": "Optional external hostname for routing"
        },
        "path": {
          "type": "string",
          "description": "URL path prefix for routing"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "External HTTPS port for the browser-facing route URL"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "http": {
          "type": "boolean",
          "description": "Enable Caddy HTTP metrics"
        }
      }
    }
  }
}
